<%- include("partials/header") %>

<section class="card">
  <h2>כניסה לאזור האישי</h2>
  <p>הזינו את קוד הגישה שקיבלתם לאחר פתיחת הבקשה.</p>
  <% if (error) { %>
  <div class="alert error"><%= error %></div>
  <% } %>
  <form method="POST" action="/my-area" class="form-grid">
    <label>
      קוד גישה
      <input type="text" name="access_token" required />
    </label>
    <button type="submit">כניסה</button>
  </form>
</section>

<%- include("partials/footer") %>
