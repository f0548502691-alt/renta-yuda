PORT=3000
SESSION_SECRET=replace-with-strong-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
APP_BASE_URL=http://localhost:3000

# Use SQLite locally by default. Uncomment DATABASE_URL for PostgreSQL deployment.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# PGSSL=disable

# Mail settings (required for real email delivery)
# MAIL_FROM=no-reply@example.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-user
# SMTP_PASS=your-pass

# Used by Vercel cron endpoint authorization
# CRON_SECRET=replace-with-random-secret
